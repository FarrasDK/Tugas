// Mendeklarasikan variabel tipe let untuk nama depan
let firstName = 'Cristiano';
// Mendeklarasikan variabel tipe let untuk nama belakang
let lastName = 'Ronaldo';
// Mendeklarasikan variabel 'age' yang nilainya diambil dari inputan pengguna melalui prompt browser
let age = prompt("Masukkan umur Cristiano Ronaldo");

// Membuat variabel 'result' menggunakan backtick (`) agar bisa menyisipkan variabel langsung ke dalam string (interpolasi)
let result = `${firstName} ${lastName} is ${age} years old`;
// Menampilkan hasil gabungan string tersebut ke layar menggunakan alert
alert(result)


// ==========================================
// VARIABLES (var, let, const)
// ==========================================
// Membuat variabel tipe var bernama 'tanggal' diisi dengan tipe number 29
var tanggal = 29;
// Variabel var bisa diubah tipe dan nilainya, di sini diubah jadi string "30"
tanggal = "30";

// Membuat variabel tipe let bernama 'namaBulan' dengan tipe string "September"
let namaBulan = "September";
// Variabel let juga dapat diubah nilainya, di sini diubah menjadi tipe number 10
namaBulan = 10;

// Membuat variabel tipe const (konstan) yang nilainya mutlak dan tidak boleh diubah-ubah lagi setelah dideklarasikan
const tahun = "2022";

// Menampilkan pesan pop-up hasil penggabungan antara variabel dan spasi menggunakan tanda tambah (+)
alert(tanggal + " " + namaBulan + " "+tahun)
