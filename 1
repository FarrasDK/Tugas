// ==========================================
// DESTRUCTURING ASSIGNMENT
// ==========================================
// Membuat sebuah konstanta (const) bernama 'book' yang menyimpan data berupa objek
const book = {
  // Properti 'title' menyimpan nilai string "Manusia Setengah Salmon"
  "title": "Manusia Setengah Salmon",
  // Properti 'author' menyimpan nilai string "Raditya Dika"
  "author": "Raditya Dika",
  // Properti 'publisher' menyimpan data objek bersarang (nested object)
  "publisher": {
    // Sub-properti 'name' menyimpan nilai string "Gagas Media"
    "name": "Gagas Media",
    // Sub-properti 'address' menyimpan nilai string "Jakarta Selatan"
    "address": "Jakarta Selatan"
  }
}

// Memecah (destructuring) properti dari objek 'book' menjadi variabel terpisah
// - 'title' diubah nama variabelnya menjadi 'bookTitle'
// - 'author' diberi nilai default "RD" (walau di objek nilainya tetap "Raditya Dika")
// - 'publisher' dipecah lebih dalam untuk mengambil properti 'name' dan 'address'
const {title: bookTitle, author = "RD", publisher:{name, address}} = book;

// Mencetak hasil ekstraksi variabel ke dalam konsol browser/terminal
console.log(bookTitle, author, name, address);


