// ==========================================
// CLASS
// ==========================================
// Membuat cetak biru (blueprint) objek dengan nama class 'Holiday'
class Holiday {
  // Method constructor adalah blok kode yang otomatis dijalankan pertama kali saat objek baru dibuat
  constructor(destination, days) {
    // Mengisi properti 'destination' pada kelas ini dengan nilai parameter 'destination'
    this.destination = destination;
    // Mengisi properti 'days' pada kelas ini dengan nilai parameter 'days'
    this.days = days;
  }
  
  // Membuat method (fungsi di dalam class) bernama 'info'
  info() {
    // Menampilkan pesan pop-up berisi data dari properti objek
    alert(this.destination + " will take " + this.days + " days.");
  }
}

// Membuat objek (instance) baru bernama 'trip' dari class 'Holiday' dengan nilai "Semeru" dan 10
var trip = new Holiday("Semeru", 10);
// Menjalankan method 'info()' milik objek 'trip'
trip.info();


